      "expected_output": "FIND:0:NULL",
      "expected_errno": 0,
      "mode": "both"
    },
    {
      "name": "hcreate_r_hsearch_r_hdestroy_r_replace_existing_data",
      "function": "hsearch_r",
      "spec_section": "POSIX.1-2017 hsearch_r",
      "inputs": {
        "scenario": "replace_existing",
        "table_capacity": 8,
        "key": "beta",
