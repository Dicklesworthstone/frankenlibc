  "description": "POSIX and XSI search.h operations covering hcreate/hsearch/hdestroy, hcreate_r/hsearch_r/hdestroy_r, tsearch/tfind/tdelete/twalk, lfind/lsearch, and insque/remque against host glibc and frankenlibc ABI entrypoints.",
  "spec_reference": "POSIX.1-2017 search.h; X/Open System Interfaces for insque/remque",
  "cases": [
    {
      "name": "hcreate_hsearch_hdestroy_replace_existing_data",
      "function": "hsearch",
