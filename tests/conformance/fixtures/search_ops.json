      "function": "tsearch",
      "spec_section": "POSIX.1-2017 tsearch",
      "inputs": {
        "keys": [10, 5, 15],
        "find": [5, 99]
      },
      "expected_output": "ROOT:10|FIND:5=1|FIND:99=0",
      "expected_errno": 0,
      "mode": "both"
    },
    {
      "name": "tfind_existing_and_missing",
      "function": "tfind",
      "spec_section": "POSIX.1-2017 tfind",
      "inputs": {
        "keys": [10, 5, 15],
        "find": [15, 42]
      },
      "expected_output": "ROOT:10|FIND:15=1|FIND:42=0",
      "expected_errno": 0,
      "mode": "both"
    },
    {
      "name": "tdelete_removes_leaf",
      "function": "tdelete",
      "spec_section": "POSIX.1-2017 tdelete",
      "inputs": {
        "keys": [10, 5, 15],
        "delete": 5,
