      "inputs": {
        "scenario": "replace_existing",
        "table_capacity": 8,
        "key": "alpha",
        "first_data": 111,
        "second_data": 222
      },
      "expected_output": "ENTER:1:111|ENTER:1:111|FIND:1:111",
      "expected_errno": 0,
      "mode": "both"
    },
    {
      "name": "hcreate_hsearch_hdestroy_find_missing_key",
      "function": "hsearch",
