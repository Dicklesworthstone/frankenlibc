{
  "version": "v1",
  "family": "signal_ops",
  "captured_at": "2026-02-13T00:00:00Z",
  "description": "Mode-specific parity fixtures for signal operations (kill, raise, signal, sigaction, ssignal, gsignal). Strict mode matches host behavior; hardened mode preserves legacy signal semantics for valid and invalid inputs.",
  "cases": [
    {
      "name": "raise_zero_strict",
      "function": "raise",
      "spec_section": "POSIX raise",
      "inputs": { "sig": 0 },
      "expected_output": "0",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Signal 0 is a null signal, always succeeds"
    },
    {
      "name": "kill_self_zero_strict",
      "function": "kill",
      "spec_section": "POSIX kill",
      "inputs": { "pid": 0, "sig": 0 },
      "expected_output": "0",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Signal 0 to own process group"
    },
    {
      "name": "signal_install_sigusr1_both",
      "function": "signal",
      "spec_section": "POSIX signal",
      "inputs": { "sig": 10 },
      "expected_output": "INSTALLED:0",
      "expected_errno": 0,
      "mode": "both",
      "note": "Installing a SIGUSR1 handler via signal() should succeed in both modes"
    },
    {
      "name": "signal_invalid_signal_both",
      "function": "signal",
      "spec_section": "POSIX signal",
      "inputs": { "sig": 1024 },
      "expected_output": "SIG_ERR:22",
      "expected_errno": 22,
      "mode": "both",
      "note": "Invalid signals should return SIG_ERR and set EINVAL"
    },
    {
      "name": "kill_invalid_signal_strict",
      "function": "kill",
      "spec_section": "POSIX kill",
      "inputs": { "pid": 1, "sig": 999 },
      "expected_output": "-1",
      "expected_errno": 22,
      "mode": "strict",
      "note": "Invalid signal number returns EINVAL"
    },
    {
      "name": "sigaction_query_strict",
      "function": "sigaction",
      "spec_section": "POSIX sigaction",
      "inputs": { "signum": 2, "act": null },
      "expected_output": "0",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Query current SIGINT handler without setting"
    },
    {
      "name": "ssignal_install_sigusr1_both",
      "function": "ssignal",
      "spec_section": "System V ssignal",
      "inputs": { "sig": 10 },
      "expected_output": "INSTALLED:0",
      "expected_errno": 0,
      "mode": "both",
      "note": "Installing a SIGUSR1 handler should succeed in both modes"
    },
    {
      "name": "ssignal_invalid_signal_both",
      "function": "ssignal",
      "spec_section": "System V ssignal",
      "inputs": { "sig": 1024 },
      "expected_output": "SIG_ERR:22",
      "expected_errno": 22,
      "mode": "both",
      "note": "Invalid signals should return SIG_ERR and set EINVAL"
    },
    {
      "name": "gsignal_sigusr1_delivery_both",
      "function": "gsignal",
      "spec_section": "System V gsignal",
      "inputs": { "sig": 10, "preinstall": "ssignal" },
      "expected_output": "0:10:0",
      "expected_errno": 0,
      "mode": "both",
      "note": "gsignal should deliver SIGUSR1 to a handler installed by ssignal"
    },
    {
      "name": "gsignal_invalid_signal_both",
      "function": "gsignal",
      "spec_section": "System V gsignal",
      "inputs": { "sig": 1024 },
      "expected_output": "-1:0:22",
      "expected_errno": 22,
      "mode": "both",
      "note": "Invalid signals should fail like raise and leave the handler hit counter untouched"
    },
    {
      "name": "raise_zero_hardened",
