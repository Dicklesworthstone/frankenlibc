{
  "version": "v1",
  "family": "stdlib/sort",
  "captured_at": "2026-02-09T00:00:00Z",
  "description": "Mode-specific parity fixtures for ISO C stdlib sort and search operations (qsort, bsearch) over byte arrays.",
  "spec_reference": "ISO C qsort, bsearch",
  "cases": [
    {
      "name": "qsort_int",
      "function": "qsort",
      "spec_section": "ISO C qsort",
      "inputs": { "base": [4, 2, 3, 1], "nmemb": 4, "size": 1, "type": "u8" },
      "expected_output": "[1, 2, 3, 4]",
      "expected_errno": 0,
      "mode": "strict"
    },
    {
      "name": "bsearch_found",
      "function": "bsearch",
      "spec_section": "ISO C bsearch",
      "inputs": { "key": [3], "base": [1, 2, 3, 4], "nmemb": 4, "size": 1, "type": "u8" },
      "expected_output": "FOUND",
      "expected_errno": 0,
      "mode": "strict"
    },
    {
      "name": "bsearch_not_found",
      "function": "bsearch",
      "spec_section": "ISO C bsearch",
      "inputs": { "key": [5], "base": [1, 2, 3, 4], "nmemb": 4, "size": 1, "type": "u8" },
      "expected_output": "NULL",
      "expected_errno": 0,
      "mode": "strict"
    },
    {
      "name": "qsort_empty_strict",
      "function": "qsort",
      "spec_section": "ISO C qsort",
      "inputs": { "base": [], "nmemb": 0, "size": 1, "type": "u8" },
      "expected_output": "[]",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Empty array is already sorted"
    },
    {
      "name": "qsort_single_strict",
      "function": "qsort",
      "spec_section": "ISO C qsort",
      "inputs": { "base": [42], "nmemb": 1, "size": 1, "type": "u8" },
      "expected_output": "[42]",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Single element is already sorted"
    },
    {
      "name": "qsort_duplicates_strict",
      "function": "qsort",
      "spec_section": "ISO C qsort",
      "inputs": { "base": [3, 1, 2, 1, 3, 2], "nmemb": 6, "size": 1, "type": "u8" },
      "expected_output": "[1, 1, 2, 2, 3, 3]",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Duplicate values preserved"
    },
    {
      "name": "qsort_reversed_strict",
      "function": "qsort",
      "spec_section": "ISO C qsort",
      "inputs": { "base": [5, 4, 3, 2, 1], "nmemb": 5, "size": 1, "type": "u8" },
      "expected_output": "[1, 2, 3, 4, 5]",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Reverse-sorted array"
    },
    {
      "name": "bsearch_first_element_strict",
      "function": "bsearch",
      "spec_section": "ISO C bsearch",
      "inputs": { "key": [1], "base": [1, 2, 3, 4, 5], "nmemb": 5, "size": 1, "type": "u8" },
      "expected_output": "FOUND",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Find first element"
    },
    {
      "name": "bsearch_last_element_strict",
      "function": "bsearch",
      "spec_section": "ISO C bsearch",
      "inputs": { "key": [5], "base": [1, 2, 3, 4, 5], "nmemb": 5, "size": 1, "type": "u8" },
      "expected_output": "FOUND",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Find last element"
    },
    {
      "name": "bsearch_empty_strict",
      "function": "bsearch",
      "spec_section": "ISO C bsearch",
      "inputs": { "key": [1], "base": [], "nmemb": 0, "size": 1, "type": "u8" },
      "expected_output": "NULL",
      "expected_errno": 0,
      "mode": "strict",
      "note": "Search in empty array"
    },
    {
      "name": "qsort_int_hardened",
      "function": "qsort",
      "spec_section": "ISO C qsort",
      "inputs": { "base": [4, 2, 3, 1], "nmemb": 4, "size": 1, "type": "u8" },
      "expected_output": "[1, 2, 3, 4]",
      "expected_errno": 0,
      "mode": "hardened"
    },
    {
      "name": "bsearch_found_hardened",
      "function": "bsearch",
      "spec_section": "ISO C bsearch",
      "inputs": { "key": [3], "base": [1, 2, 3, 4], "nmemb": 4, "size": 1, "type": "u8" },
      "expected_output": "FOUND",
      "expected_errno": 0,
      "mode": "hardened"
    }
  ]
}
