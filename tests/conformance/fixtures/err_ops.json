      "function": "warn",
      "spec_section": "BSD err(3) warn",
      "inputs": {
        "format": "lookup",
        "errno": 2
      },
      "expected_output": {
        "stderr_body": "lookup: No such file or directory\n",
        "with_errno": true,
        "exits": false
      },
      "expected_errno": 2,
      "mode": "both",
      "note": "Validated by conformance_diff_err_h::diff_warn_errno_suffix against glibc stderr body."
    },
    {
