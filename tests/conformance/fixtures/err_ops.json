        "stderr_body": "plain warning\n",
        "with_errno": false,
        "exits": false
      },
      "expected_errno": 0,
      "mode": "both",
      "note": "Validated by conformance_diff_err_h::diff_warnx_message_body against glibc stderr body."
    },
