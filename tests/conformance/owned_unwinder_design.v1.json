  "required_entrypoints": {
    "_Unwind_RaiseException": {
      "signature": "fn(exception: *mut _Unwind_Exception) -> _Unwind_Reason_Code",
      "purpose": "Begin exception propagation (phase 1: search, phase 2: cleanup)"
    },
    "_Unwind_Resume": {
      "signature": "fn(exception: *mut _Unwind_Exception) -> !",
      "purpose": "Resume propagation after cleanup handler"
    },
    "_Unwind_DeleteException": {
      "signature": "fn(exception: *mut _Unwind_Exception)",
      "purpose": "Free exception object after catch"
    },
    "_Unwind_GetGR": {
      "signature": "fn(context: *mut _Unwind_Context, reg: c_int) -> _Unwind_Word",
      "purpose": "Read general register from unwind context"
    },
    "_Unwind_SetGR": {
      "signature": "fn(context: *mut _Unwind_Context, reg: c_int, val: _Unwind_Word)",
      "purpose": "Set general register in unwind context"
    },
    "_Unwind_GetIP": {
      "signature": "fn(context: *mut _Unwind_Context) -> _Unwind_Ptr",
      "purpose": "Get instruction pointer from context"
    },
    "_Unwind_SetIP": {
      "signature": "fn(context: *mut _Unwind_Context, ip: _Unwind_Ptr)",
      "purpose": "Set instruction pointer (for landing pad)"
    },
    "_Unwind_GetLanguageSpecificData": {
      "signature": "fn(context: *mut _Unwind_Context) -> *mut c_void",
      "purpose": "Get LSDA pointer for current frame"
    },
    "_Unwind_GetRegionStart": {
      "signature": "fn(context: *mut _Unwind_Context) -> _Unwind_Ptr",
      "purpose": "Get function start address"
    },
    "_Unwind_Backtrace": {
      "signature": "fn(callback: _Unwind_Trace_Fn, arg: *mut c_void) -> _Unwind_Reason_Code",
      "purpose": "Walk stack frames for backtrace"
    }
  },
