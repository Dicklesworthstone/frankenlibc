{
  "schema_version": "v1",
  "bead_id": "bd-ewv1l",
  "gate_id": "hermetic-resolver-nss-semantic-kernels-v1",
  "description": "Semantic-kernel promotion gate for the hermetic NSS/resolver lab. This consumes the loopback-only lab runner output and checks actual semantic invariants for hosts, services, passwd, group, resolv.conf, nsswitch, fake DNS cache/timeout/poisoning, and search-domain order.",
  "freshness": {
    "required_source_commit": "current",
    "lab_report_source_commit_policy": "semantic report and source lab report must carry the same current git commit"
  },
  "sources": {
    "lab_manifest": "tests/conformance/hermetic_nss_resolver_lab.v1.json",
    "lab_runner": "scripts/run_hermetic_nss_resolver_lab.sh",
    "resolver_fixture": "tests/conformance/fixtures/resolver.json",
    "resolver_nss_hard_parts": "tests/conformance/resolver_nss_hard_parts.v1.json",
    "oracle_precedence_divergence": "tests/conformance/oracle_precedence_divergence.v1.json",
    "user_environment_coverage": "tests/conformance/user_environment_coverage_matrix.v1.json",
    "resolver_conformance_test": "crates/frankenlibc-harness/tests/resolver_conformance_test.rs",
    "nss_lab_execution_test": "crates/frankenlibc-harness/tests/hermetic_nss_resolver_lab_execution_test.rs"
  },
  "execution_policy": {
    "default_runner": "rch_only",
    "real_network_allowed": false,
    "real_network_envvar_override": "FRANKENLIBC_NSS_LAB_ALLOW_NETWORK",
    "lab_runner_command": "scripts/run_hermetic_nss_resolver_lab.sh",
    "cargo_validation_command": "rch exec -- cargo test -p frankenlibc-harness --test hermetic_resolver_nss_semantic_kernels_test -- --nocapture"
  },
  "required_log_fields": [
    "trace_id",
    "bead_id",
    "kernel_id",
    "scenario_id",
    "runtime_mode",
    "semantic_domain",
    "oracle_kind",
    "expected",
    "actual",
    "artifact_refs",
    "source_commit",
    "target_dir",
    "failure_signature"
  ],
  "required_semantic_domains": [
    "hosts",
    "services",
    "passwd",
    "group",
    "resolv_conf",
    "nsswitch",
    "dns_cache",
    "dns_timeout",
    "dns_poisoning",
    "search_domain"
  ],
  "required_runtime_modes": [
    "strict",
    "hardened"
  ],
  "diagnostic_signatures": [
    {
      "id": "missing_field",
      "meaning": "A required manifest, source, semantic kernel, or lab row field is absent."
    },
    {
      "id": "stale_artifact",
      "meaning": "The semantic gate or consumed lab report is not tied to the current source commit."
    },
    {
      "id": "missing_source_artifact",
      "meaning": "A source artifact, fake-root file, scenario artifact, or lab output is missing."
    },
    {
      "id": "missing_semantic_kernel",
      "meaning": "A required semantic domain or strict/hardened row is absent."
    },
    {
      "id": "real_network_required",
      "meaning": "A manifest attempts to permit real network access for hermetic resolver evidence."
    },
    {
      "id": "semantic_kernel_mismatch",
      "meaning": "A semantic kernel computed from fake-root or lab JSONL output differs from the expected value."
    },
    {
      "id": "unexpected_dns_egress",
      "meaning": "The consumed lab report indicates network traffic outside loopback-only fake DNS evidence."
    },
    {
      "id": "unsupported_lookup_family",
      "meaning": "A kernel requests a domain, scenario, or lookup family outside the supported hermetic lab set."
    }
  ],
  "semantic_kernels": [
    {
      "kernel_id": "hosts-files-hermetic-local",
      "semantic_domain": "hosts",
      "scenario_id": "nss-hosts-files-only",
      "runtime_modes": [
        "strict",
        "hardened"
      ],
      "oracle_kind": "files_db_replay",
      "fake_root_file": "etc/hosts",
      "query": "hermetic.local",
      "expected": {
        "addresses": [
          "198.51.100.7"
        ],
        "lookup_source": "files",
        "dns_fallback": false
      },
      "artifact_refs": [
        "tests/conformance/hermetic_nss_resolver_lab.v1.json",
        "scripts/run_hermetic_nss_resolver_lab.sh"
      ]
    },
