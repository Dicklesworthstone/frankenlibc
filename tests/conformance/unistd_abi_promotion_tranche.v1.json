    "accepted_host_symbols": [
      "<dynamic>",
      "_IO_list_all",
      "__errno_location",
      "abort",
      "bootstrap_host_libio_exports",
      "bootstrap_host_symbols",
      "close",
      "ensure_host_libio_exit_safe",
      "fflush_managed_only_for_abort",
      "flush_stream",
      "ftruncate",
      "host_errno_location_raw",
      "load_host_symbol",
      "lseek",
      "mmap",
      "parse_getopt_short",
      "pread",
      "pwrite",
      "registry",
      "sendfile",
      "set_abi_errno",
      "sigaddset",
      "sigemptyset",
      "sys_write_fd",
      "truncate",
      "write_host_errno_if_available"
    ],
    "accepted_delegation_kinds": [
      "alias_to_host_delegating_symbol",
      "cached_host_errno_symbol",
      "resolve_host_symbol_raw_dynamic",
      "resolve_host_symbol_raw_literal"
    ]
  },
