  "subject": "tls_cache_epoch_invalidation",
  "cache_size_entries": 1024,
  "epoch_source": "SHARD_EPOCHS[tls_cache_shard_for(user_base)]",
  "num_shards": 16,
  "schema_version_2_notes": [
    "Schema bumped from 1 to 2 when the cross-thread invalidation stamp was sharded across NUM_TLS_CACHE_SHARDS atomics.",
    "Cache entries now record (shard_idx, shard_epoch) instead of a single global epoch.",
    "Each case below is interpreted as: free a slot whose home shard matches the cached entry, so the relevant shard epoch bumps from E to E+1.",
    "A free in a different shard MUST NOT invalidate this entry; that property is pinned by tls_cache.rs::bump_of_unrelated_shard_does_not_invalidate_entry."
  ],
  "cases": [
    {
      "id": "lookup_epoch_mismatch_forces_miss",
      "api": "lookup",
      "inserted_epoch": "E",
      "current_epoch": "E+1",
      "lookup_addr_matches": true,
      "expected_lookup": "miss",
      "expected_hit_delta": 0,
      "expected_miss_delta": 1,
      "expected_entry_valid_after_lookup": false
    },
    {
      "id": "lookup_hit_only_epoch_mismatch_self_cleans_without_miss_accounting",
      "api": "lookup_hit_only",
      "inserted_epoch": "E",
      "current_epoch": "E+1",
      "lookup_addr_matches": true,
      "expected_lookup": "miss",
      "expected_hit_delta": 0,
      "expected_miss_delta": 0,
      "expected_entry_valid_after_lookup": false
    },
    {
      "id": "second_lookup_after_self_clean_still_misses",
      "api": "lookup",
      "inserted_epoch": "E",
      "current_epoch": "E+1",
      "lookup_addr_matches": true,
      "expected_lookup": "miss",
      "expected_hit_delta": 0,
      "expected_miss_delta": 1,
      "expected_entry_valid_after_lookup": false
    }
  ]
}
