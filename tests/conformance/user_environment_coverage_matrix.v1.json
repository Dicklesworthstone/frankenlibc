  "state_values": [
    "required",
    "optional",
    "skipped",
    "blocked"
  ],
  "evidence_states": [
    "claim_blocked",
    "current",
    "flaky",
    "skipped",
    "stale",
    "unsupported"
  ],
  "reason_codes": [
    {
      "id": "interpose_artifact_missing",
      "category": "blocked",
      "support_merge_allowed": false,
      "description": "Current tree has no built libfrankenlibc_abi.so or libfrankenlibc_replace.so artifact for the row."
    },
    {
      "id": "aarch64_bringup_missing",
      "category": "blocked",
      "support_merge_allowed": false,
      "description": "Aarch64 is an explicit bring-up obligation but has no current runner evidence."
    },
    {
      "id": "l1_claim_control_blocked",
      "category": "blocked",
      "support_merge_allowed": false,
      "description": "L1 remains blocked until replacement-level claim-control promotes current and release levels together."
    },
    {
      "id": "resolver_online_external_network",
      "category": "flaky",
      "support_merge_allowed": false,
      "description": "Online resolver behavior depends on external network state and cannot be merged into supported status without current deterministic evidence."
    },
    {
      "id": "resolver_offline_fixture_missing",
      "category": "blocked",
      "support_merge_allowed": false,
      "description": "Offline resolver behavior is required but no current direct workload replay artifact proves it."
    },
    {
      "id": "locale_fixture_only_no_interpose",
      "category": "blocked",
      "support_merge_allowed": false,
      "description": "Locale fixture evidence exists, but user workload interpose evidence is still missing."
    },
    {
      "id": "filesystem_permission_fixture_missing",
      "category": "blocked",
      "support_merge_allowed": false,
      "description": "Filesystem permission variation is required but no current workload replay proves it."
    },
    {
      "id": "pthread_fixture_only_no_workload_smoke",
      "category": "blocked",
      "support_merge_allowed": false,
      "description": "Threading fixture evidence exists, but no user workload smoke row proves this environment."
    },
    {
      "id": "package_manager_evidence_stale",
      "category": "stale",
      "support_merge_allowed": false,
      "description": "Package-manager style workload evidence is intentionally stale until regenerated from current artifacts."
    },
    {
      "id": "standalone_l2_unproven",
      "category": "unsupported",
      "support_merge_allowed": false,
      "description": "Standalone L2 replacement is not supported until startup, host-dependency, and direct-link evidence is current."
    },
    {
      "id": "optional_dependency_absent",
      "category": "skipped",
      "support_merge_allowed": false,
      "description": "Optional dependency row is tracked but intentionally skipped in the current environment."
    }
  ],
  "coverage_requirements": {
    "architectures": [
      "x86_64",
      "aarch64"
    ],
    "runtime_modes": [
      "strict",
      "hardened"
    ],
    "replacement_levels": [
      "L0",
      "L1"
    ],
    "states": [
      "required",
      "blocked",
      "optional",
      "skipped"
    ],
    "evidence_states": [
      "claim_blocked",
      "flaky",
      "skipped",
      "stale",
      "unsupported"
    ],
