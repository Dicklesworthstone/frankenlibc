        "bash scripts/check_strict_hardened_evidence_e2e.sh",
        "bash scripts/check_semantic_contract_inventory.sh",
        "bash scripts/check_semantic_contract_drift.sh",
        "rch exec -- env CARGO_TARGET_DIR=target/rch-strict-hardened-semantic-source-tests cargo test -p frankenlibc-harness --test mode_semantics_test --test hardened_repair_deny_matrix_test --test mode_contract_lock_test --test runtime_mode_evidence_logging_coverage_test --test strict_hardened_evidence_e2e_test --test semantic_contract_inventory_test --test semantic_contract_drift_scan_test -- --nocapture",
        "rch exec -- env CARGO_TARGET_DIR=target/rch-strict-hardened-semantic-completion-clippy cargo clippy -p frankenlibc-harness --test strict_hardened_semantic_closure_completion_contract_test -- -D warnings"
      ]
    }
  ],
