    "forbidden_next_actions_when_blocked": [
      "start new Rust implementation requiring cargo proof",
      "count local cargo as validation proof",
      "run cleanup or deletion without exact written approval",
      "open a feature branch or worktree"
    ]
  },
  "report_contract": {
