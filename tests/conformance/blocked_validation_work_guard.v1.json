    "decision_when_rch_admissible": "resume_cargo_validation_queue",
    "decision_when_rch_blocked_and_dependents_waiting": "avoid_new_cargo_backed_work",
    "allowed_next_actions_when_blocked": [
      "refresh read-only RCH evidence",
      "recover stale in-progress beads before new discovery",
      "request exact operator approval for cleanup candidates",
      "ship no-cargo checker or contract evidence",
      "close tracker-only work that does not require cargo validation"
