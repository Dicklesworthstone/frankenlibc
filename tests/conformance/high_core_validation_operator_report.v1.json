{
  "schema_version": "v1",
  "contract_id": "high-core-validation-operator-report",
  "bead": "bd-2syj4",
  "purpose": "Generate a compact operator report from merged high-core validation results and longitudinal cost telemetry.",
  "inputs": {
    "merge_report": "target/conformance/high_core_validation/merge.report.json",
    "cost_report": "target/conformance/high_core_validation/costs.report.json"
  },
  "outputs": {
    "json_report": "target/conformance/high_core_validation/operator.report.json",
    "markdown_report": "target/conformance/high_core_validation/operator.report.md",
    "event_log": "target/conformance/high_core_validation/operator.events.log.jsonl"
  },
  "report_contract": {
    "output_path": "target/conformance/high_core_validation/operator.report.json",
    "markdown_path": "target/conformance/high_core_validation/operator.report.md",
    "log_path": "target/conformance/high_core_validation/operator.events.log.jsonl",
    "must_materialize": [
      "schema_version",
      "bead",
      "status",
      "source_merge_report",
      "source_cost_report",
      "sections",
      "summary",
      "lane_health",
      "recent_p95_cost",
      "failed_units",
      "skipped_units",
      "stale_artifact_warnings",
      "rch_rerun_commands",
      "report_path",
      "markdown_path",
      "log_path",
      "report_contract_fields",
      "contract_status",
      "contract_errors"
    ]
  },
  "required_sections": [
    "lane_health",
    "recent_p95_cost",
    "failed_units",
    "skipped_units",
    "stale_artifact_warnings",
    "rch_rerun_commands"
  ],
  "status_policy": {
    "failed_units_make_report_failed": true,
    "skipped_units_are_never_hidden_by_green_aggregate": true,
    "stale_artifacts_warn_without_reclassifying_passed_units": true,
    "expensive_p95_ms_threshold": 600000
  },
  "required_failure_fields": [
    "unit_id",
    "shard_id",
    "failure_signature",
    "first_failing_artifact",
    "reproduction_command"
  ],
  "required_rerun_fields": ["unit_id", "shard_id", "status", "rch_command"]
}
