{
  "schema_version": "completion_contract_rch_proof_manifest_lint.v1",
  "bead": "bd-waaa6.4",
  "purpose": "Fail-closed lint for completion-contract validation commands that claim Rust proof via cargo. Cargo proof commands must be remote-only rch executions with isolated target dirs and targeted test/check/clippy lanes.",
  "policy": {
    "required_remote_env": "RCH_FORCE_REMOTE=true",
    "fail_closed_remote_env": "RCH_REQUIRE_REMOTE=1",
    "legacy_remote_env_markers": [
      "RCH_FORCE_REMOTE=true"
    ],
    "required_launcher_tokens": [
      "rch",
      "exec"
    ],
    "required_target_dir_env": "CARGO_TARGET_DIR=",
    "forbidden_target_dir_values": [
      "<target>",
      ""
    ],
    "forbidden_proof_markers": [
      "[RCH] local",
      "remote execution failed"
    ],
    "required_completion_test_lanes": [
      "test",
      "check",
      "clippy"
    ],
    "required_surface_lane": "test"
  },
  "contract_paths": [
    "tests/conformance/string_memory_hotpaths_wave05_completion_contract.v1.json",
    "tests/conformance/string_memory_hotpaths_wave06_completion_contract.v1.json",
    "tests/conformance/string_memory_hotpaths_wave10_completion_contract.v1.json",
    "tests/conformance/string_memory_hotpaths_wave11_completion_contract.v1.json",
    "tests/conformance/unistd_process_filesystem_wave05_completion_contract.v1.json"
  ],
  "launcher_only_contract_paths": [
    "tests/conformance/raw_syscall_veneer_completion_contract.v1.json",
    "tests/conformance/math_core_diff_completion_contract.v1.json"
  ],
  "expected_positive_contracts": [
    "string_memory_hotpaths_wave05_completion_contract",
    "string_memory_hotpaths_wave06_completion_contract",
    "string_memory_hotpaths_wave10_completion_contract",
    "string_memory_hotpaths_wave11_completion_contract",
    "unistd_process_filesystem_wave05_completion_contract"
  ],
  "expected_launcher_only_contracts": [
    "raw_syscall_veneer_completion_contract",
    "math_core_diff_completion_contract"
  ],
  "fail_closed_contract_paths": [
    "tests/conformance/completion_contract_rch_proof_manifest_lint.v1.json"
  ],
  "expected_fail_closed_contracts": [
    "completion_contract_rch_proof_manifest_lint"
  ],
  "required_failure_signatures": [
    "bare_cargo_command",
    "missing_remote_env",
    "missing_rch_exec",
    "missing_rch_exec_env",
    "shell_wrapped_cargo",
    "missing_isolated_target_dir",
    "missing_fail_closed_remote_env",
    "legacy_remote_env_marker",
    "missing_targeted_test_lane",
    "missing_targeted_check_lane",
    "missing_targeted_clippy_lane",
    "local_fallback_marker"
  ],
  "outputs": {
    "report": "target/conformance/completion_contract_rch_proof_manifest_lint.report.json",
    "log": "target/conformance/completion_contract_rch_proof_manifest_lint.log.jsonl"
  },
  "report_contract": {
    "output_path": "target/conformance/completion_contract_rch_proof_manifest_lint.report.json",
    "log_path": "target/conformance/completion_contract_rch_proof_manifest_lint.log.jsonl",
    "must_materialize": [
      "schema_version",
      "bead",
      "status",
      "summary",
      "policy",
      "contract_reports",
      "errors",
      "artifact_refs",
      "source_commit",
      "report_path",
      "log_path",
      "report_contract_fields",
      "contract_status",
      "contract_errors"
    ]
  },
  "required_validation_commands": [
    "jq empty tests/conformance/completion_contract_rch_proof_manifest_lint.v1.json",
    "bash -n scripts/check_completion_contract_rch_proof_manifest_lint.sh",
    "bash scripts/check_completion_contract_rch_proof_manifest_lint.sh",
    "jq empty target/conformance/completion_contract_rch_proof_manifest_lint.report.json",
    "jq empty target/conformance/completion_contract_rch_proof_manifest_lint.log.jsonl",
    "jq -e '.contract_status == \"pass\" and .status == \"pass\" and .report_path == \"target/conformance/completion_contract_rch_proof_manifest_lint.report.json\"' target/conformance/completion_contract_rch_proof_manifest_lint.report.json",
    "RCH_REQUIRE_REMOTE=1 RCH_VISIBILITY=summary rch exec -- env CARGO_TARGET_DIR=/tmp/rch_target_frankenlibc_goldbeaver_rch_proof_lint_test cargo test -p frankenlibc-harness --test completion_contract_rch_proof_manifest_lint_test -- --nocapture",
    "RCH_REQUIRE_REMOTE=1 RCH_VISIBILITY=summary rch exec -- env CARGO_TARGET_DIR=/tmp/rch_target_frankenlibc_goldbeaver_rch_proof_lint_check cargo check -p frankenlibc-harness --test completion_contract_rch_proof_manifest_lint_test",
    "RCH_REQUIRE_REMOTE=1 RCH_VISIBILITY=summary rch exec -- env CARGO_TARGET_DIR=/tmp/rch_target_frankenlibc_goldbeaver_rch_proof_lint_clippy cargo clippy -p frankenlibc-harness --test completion_contract_rch_proof_manifest_lint_test -- -D warnings"
  ]
}
