{
  "schema_version": "fuzz_smoke_manifest.v1",
  "bead": "bd-n0apt.3",
  "description": "Representative remote rch smoke tier for fuzz targets with checked proof-report validation.",
  "artifacts": {
    "checker": "scripts/check_fuzz_smoke_manifest.sh",
    "report": "target/conformance/fuzz_smoke_manifest.report.json",
    "proof_schema": "fuzz_smoke_proof.v1",
    "harness_test": "crates/frankenlibc-harness/tests/fuzz_smoke_manifest_test.rs"
  },
  "policy": {
    "min_corpus_files": 1,
    "remote_command_prefix": "RCH_FORCE_REMOTE=true RCH_VISIBILITY=summary rch exec -- env",
    "local_fallback_marker": "[RCH] local (remote execution failed)",
    "forbid_shell_wrapped_cargo": true,
    "require_done_runs_at_least_corpus_files": true
  },
  "smoke_targets": [
    {
      "target": "fuzz_b64",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_b64",
      "reason": "low corpus count and parser-style encoded-data surface"
    },
    {
      "target": "fuzz_c11threads",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_c11threads",
      "reason": "recently added directed C11 thread lifecycle seeds"
    },
    {
      "target": "fuzz_ctype",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_ctype",
      "reason": "recently added directed ctype operation seeds"
    },
    {
      "target": "fuzz_loc_codec",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_loc_codec",
      "reason": "low corpus count across locale codec parsing"
    },
    {
      "target": "fuzz_math",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_math",
      "reason": "low corpus count for numeric edge behavior"
    },
    {
      "target": "fuzz_membrane",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_membrane",
      "reason": "low corpus count for the safety membrane surface"
    },
    {
      "target": "fuzz_printf_adversarial",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_printf_adversarial",
      "reason": "directed adversarial printf parser seeds"
    },
    {
      "target": "fuzz_pthread_keys",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_pthread_keys",
      "reason": "low corpus count for pthread TLS key behavior"
    },
    {
      "target": "fuzz_regex",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_regex",
      "reason": "low corpus count for regex parser and NFA behavior"
    },
    {
      "target": "fuzz_string",
      "corpus_path": "crates/frankenlibc-fuzz/corpus/fuzz_string",
      "reason": "low corpus count for high-value string primitives"
    }
  ],
  "validation": {
    "commands": [
      "jq empty tests/conformance/fuzz_smoke_manifest.v1.json",
      "bash -n scripts/check_fuzz_smoke_manifest.sh",
      "bash scripts/check_fuzz_smoke_manifest.sh --print-commands",
      "bash scripts/check_fuzz_smoke_manifest.sh --proof <proof.json>",
      "rustfmt --edition 2024 --check crates/frankenlibc-harness/tests/fuzz_smoke_manifest_test.rs",
      "RCH_FORCE_REMOTE=true RCH_VISIBILITY=summary rch exec -- env CARGO_TARGET_DIR=/tmp/rch_target_frankenlibc_fuzz_smoke_test cargo test -p frankenlibc-harness --test fuzz_smoke_manifest_test -- --nocapture",
      "RCH_FORCE_REMOTE=true RCH_VISIBILITY=summary rch exec -- env CARGO_TARGET_DIR=/tmp/rch_target_frankenlibc_fuzz_smoke_clippy cargo clippy -p frankenlibc-harness --test fuzz_smoke_manifest_test -- -D warnings"
    ]
  }
}
