{
  "schema_version": "rch_pressure_approval_packet_schema.v1",
  "bead": "bd-xvsum",
  "purpose": "Define the approval-safe packet shape used when rch cannot select a remote worker because storage pressure blocks all cargo validation lanes.",
  "safety_policy": {
    "collection_mode": "read_only",
    "destructive_actions_authorized_by_this_schema": false,
    "destructive_action_rule": "Packet generators may report candidate cleanup paths, but they must not delete files, release ballast, rewrite git state, run package cleanup, or execute any command that can remove or overwrite data. Cleanup remains blocked until the user provides explicit written approval for exact paths and commands.",
    "must_distinguish": [
      "read_only_evidence",
      "requires_explicit_approval",
      "executed_actions"
    ],
    "local_cargo_fallback_rule": "A packet may record local fallback as a failure signature only. It must never count local cargo execution as validation proof."
  },
  "required_top_level_fields": [
    "schema_version",
    "packet_id",
    "generated_at_utc",
    "project",
    "repo_state",
    "rch_gate",
    "workers",
    "cleanup_candidates",
    "recommended_cleanup_candidates",
    "approval_request",
    "executed_actions",
    "validation_commands",
    "artifact_paths"
  ],
  "repo_state_fields": [
    "cwd",
    "branch",
    "head_commit",
    "origin_main_commit",
    "origin_master_commit",
    "worktree_list",
    "dirty_summary",
    "untracked_summary"
  ],
  "rch_gate_fields": [
    "dry_run_command",
    "dry_run_exit_status",
    "would_offload",
    "worker_selection_status",
    "skip_reason",
    "required_remote_env",
    "fallback_markers_rejected"
  ],
  "worker_fields": [
    "worker_id",
    "host",
    "status",
    "pressure_state",
    "pressure_reason_code",
    "pressure_disk_free_gb",
    "pressure_disk_total_gb",
    "pressure_disk_free_ratio",
    "pressure_telemetry_fresh",
    "estimated_free_ratio_target",
    "estimated_gb_needed_to_reach_target_ratio",
    "probe_command",
    "direct_rch_probe_command",
    "direct_rch_probe_exit_status",
    "direct_rch_probe_raw_output_path",
    "probe_exit_status",
    "probe_failure_signature",
    "df_snapshot",
    "sbh_snapshot",
    "ballast_snapshot",
    "bounded_du_findings",
    "collection_errors"
  ],
  "cleanup_candidate_fields": [
    "worker_id",
    "host",
    "path",
    "size_human",
    "size_bytes",
    "estimated_size_gb",
    "candidate_rank",
    "pre_cleanup_read_only_checks",
    "source_command",
    "candidate_kind",
    "reason_it_might_help",
    "risk_notes",
    "requires_explicit_approval",
    "executed"
  ],
  "recommended_cleanup_candidate_fields": [
    "worker_id",
    "path",
    "candidate_rank",
    "estimated_gap_gb",
    "estimated_post_cleanup_free_ratio",
    "estimated_surplus_gb_after_cleanup",
    "recommendation_kind",
    "recommendation_reason"
  ],
  "allowed_worker_statuses": [
    "healthy",
    "degraded",
    "disabled",
    "unreachable",
    "unknown"
  ],
  "allowed_pressure_states": [
    "green",
    "warning",
    "critical",
    "telemetry_gap",
    "unknown"
  ],
  "allowed_probe_failure_signatures": [
    "ok",
    "RCH-E100",
    "timeout",
    "ssh_permission_denied",
    "sbh_permission_denied",
    "no_matches",
    "unknown"
  ],
  "required_failure_signatures": [
    "critical_pressure",
    "RCH-E100",
    "absent_or_non_releasable_ballast",
    "local_fallback_rejected"
  ],
  "approval_request_contract": {
    "must_include": [
      "operator_summary",
      "exact_worker_ids",
      "exact_candidate_paths",
      "smallest_sufficient_candidate_paths",
      "why_read_only_collection_is_insufficient",
      "explicit_user_text_required_before_cleanup",
      "commands_not_executed"
    ],
    "must_not_include": [
      "claim_that_cleanup_already_happened",
      "cargo_validation_success_when_worker_selection_skipped",
      "implicit_permission_to_delete"
    ]
  },
