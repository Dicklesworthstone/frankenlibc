      "category": "pthread_tls",
      "description": "pthread_create, pthread_join, C thread-local storage, and errno stay coherent in a direct-link binary.",
      "source_filename": "pthread_tls_errno.c",
      "c_source": "#include <errno.h>\n#include <pthread.h>\n#include <stdint.h>\n#include <stdio.h>\n\nstatic _Thread_local int tls_value;\n\nstatic void *worker(void *arg) {\n    (void)arg;\n    tls_value = 41;\n    errno = EDOM;\n    return (void *)(intptr_t)(tls_value + (errno == EDOM));\n}\n\nint main(void) {\n    pthread_t thread;\n    void *result = NULL;\n    if (pthread_create(&thread, NULL, worker, NULL) != 0) {\n        perror(\"pthread_create\");\n        return 2;\n    }\n    if (pthread_join(thread, &result) != 0) {\n        perror(\"pthread_join\");\n        return 3;\n    }\n    long value = (long)(intptr_t)result;\n    printf(\"pthread-tls-ok:%ld\\n\", value);\n    return value == 42 ? 0 : 4;\n}\n",
      "replacement_level": "L2",
