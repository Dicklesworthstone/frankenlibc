  "performance_claim_blocking_tests": [
    {
      "id": "stale_baseline_blocks_no_regression_claim",
      "condition": "host_baseline.source_commit is stale or capture_state is not current",
      "claim_surface": "README release compatibility_report",
      "expected_decision": "claim_blocked",
      "failure_signature": "perf_claim_stale_baseline"
    },
    {
      "id": "missing_parity_proof_blocks_performance_claim",
      "condition": "parity_evidence_refs missing or behavior proof is not passing",
      "claim_surface": "README release compatibility_report",
      "expected_decision": "claim_blocked",
      "failure_signature": "perf_claim_missing_parity_proof"
    },
    {
      "id": "microbench_only_blocks_user_workload_claim",
      "condition": "only membrane_hot_path_microbenchmark evidence exists for a user workload claim",
      "claim_surface": "README release compatibility_report",
      "expected_decision": "claim_blocked",
      "failure_signature": "perf_claim_microbench_only"
    },
    {
      "id": "parity_failing_evidence_blocks_speedup_claim",
      "condition": "behavior proof is failing even when timing is under threshold",
      "claim_surface": "README release compatibility_report",
      "expected_decision": "claim_blocked",
      "failure_signature": "perf_claim_parity_failing"
    }
  ],
