  "source_scan_roots": [
    "crates/frankenlibc-abi/src",
    "crates/frankenlibc-core/src"
  ],
  "source_scan_suffixes": [
    ".rs"
  ],
  "source_marker_radius_lines": 80,
  "scanner_rules": [
    {
      "id": "inventory_marker_freshness",
      "description": "Every semantic inventory row must point at a live ABI/core source marker close to its recorded source line."
    },
    {
      "id": "source_contract_annotation_drift",
      "description": "Fallback/no-op/unsupported/bootstrap contract annotations in ABI/core source must be represented by the semantic inventory or explicitly allowlisted with symbol and evidence reason."
    },
    {
      "id": "support_taxonomy_claim_blocker",
      "description": "support_matrix Stub=0 must remain blocked from being interpreted as zero semantic no-op/fallback/bootstrap contracts."
    },
    {
      "id": "semantic_join_freshness",
      "description": "The symbol-join artifact must cover every inventory row and preserve semantic-parity blockers."
    },
    {
      "id": "docs_claim_surface",
      "description": "README and FEATURE_PARITY must reference the semantic overlay and avoid unsupported full-parity claims."
    },
    {
      "id": "abi_export_input_presence",
      "description": "The ABI version script and joined symbol artifact must remain present as scanner inputs."
    }
  ],
  "contract_terms": [
    {
      "id": "compat_noop",
      "patterns": [
        "no-op",
        "noop"
      ]
    },
    {
      "id": "deterministic_fallback",
      "patterns": [
        "fallback",
        "safe-default"
      ]
    },
    {
      "id": "unsupported_platform_contract",
      "patterns": [
        "unsupported",
        "enosys",
        "not implemented"
      ]
    },
    {
      "id": "limited_bootstrap",
      "patterns": [
        "bootstrap",
        "phase-1"
      ]
    },
    {
      "id": "abort_only",
      "patterns": [
        "abort-only",
        "fail-stop"
      ]
    },
    {
      "id": "stub",
      "patterns": [
        "stub"
      ]
    }
  ],
  "annotation_markers": [
    "semantic contract",
    "semantic overlay",
    "support-taxonomy",
    "full replacement",
    "documented stub",
    "semantic fallback",
    "semantic no-op",
    "semantic noop",
    "semantic unsupported",
    "semantic bootstrap",
    "contract:"
  ],
  "intentional_false_positive_allowlist": [],
  "required_log_fields": [
    "trace_id",
    "bead_id",
    "scanner_rule",
    "symbol",
    "file_path",
    "expected_contract",
    "actual_contract",
    "artifact_refs",
