  "purpose": "Deterministic CI scanner for semantic contract drift between no-op, fallback, unsupported, bootstrap, and abort-only source annotations and the semantic contract inventory.",
  "inputs": {
    "semantic_contract_inventory": "tests/conformance/semantic_contract_inventory.v1.json",
    "semantic_contract_symbol_join": "tests/conformance/semantic_contract_symbol_join.v1.json",
    "support_semantic_overlay": "tests/conformance/support_semantic_overlay.v1.json",
    "support_matrix": "support_matrix.json",
