{
  "schema_version": "v1",
  "bead": "bd-bp8fl.10.5",
  "purpose": "User-visible diagnostic catalog for semantic fallback and runtime-mode decisions. The catalog explains why a call used native behavior, a raw syscall, a historical host-delegation fixture, a deterministic fallback, a hardened repair, a denial, an unsupported contract, or a no-op compatibility path without exposing unsafe internals.",
  "inputs": {
    "support_matrix": "support_matrix.json",
    "semantic_join": "tests/conformance/semantic_contract_symbol_join.v1.json",
    "replacement_levels": "tests/conformance/replacement_levels.json",
    "hardened_repair_deny_matrix": "tests/conformance/hardened_repair_deny_matrix.v1.json",
    "real_program_smoke_suite": "tests/conformance/real_program_smoke_suite.v1.json",
    "host_libc_dependency_inventory": "tests/conformance/host_libc_dependency_inventory.v1.json"
  },
  "required_record_fields": [
    "scenario_id",
    "diagnostic_type",
    "symbol",
    "api_family",
    "runtime_mode",
    "replacement_level",
    "support_status",
    "semantic_join_inventory_id",
    "semantic_class",
    "decision_path",
    "healing_action",
    "diagnostic_code",
    "user_message_id",
    "user_message",
    "support_claim",
    "artifact_refs",
    "evidence_status",
    "source_commit",
    "failure_signature",
    "expected_output"
  ],
  "required_log_fields": [
    "trace_id",
    "bead_id",
    "scenario_id",
    "symbol",
    "api_family",
    "runtime_mode",
    "replacement_level",
    "decision_path",
    "healing_action",
    "diagnostic_code",
    "user_message_id",
    "artifact_refs",
    "source_commit",
    "failure_signature"
  ],
  "diagnostic_policy": {
    "stable_output_template": "{diagnostic_code} {symbol} {runtime_mode} {replacement_level}: {user_message}",
    "support_taxonomy_alone_is_not_semantic_parity": true,
    "unsupported_or_blocked_claims_support": false,
    "host_delegation_without_current_support_matrix_row_claims_support": false,
    "redaction": {
      "forbidden_user_message_fragments": [
        "0x",
        "raw pointer",
        "heap address",
        "secret",
        "token",
        "password"
      ],
      "no_internal_addresses": true,
      "no_environment_secrets": true
    }
  },
  "diagnostic_types": [
    {
      "id": "native_behavior",
      "diagnostic_code": "FLC-DIAG-NATIVE",
      "user_message_id": "diag.native_behavior",
      "claim_policy": "may_claim_support_only_when current support matrix and fixture evidence agree",
      "meaning": "FrankenLibC selected native Rust-owned behavior for the call."
    },
    {
      "id": "host_delegation",
      "diagnostic_code": "FLC-DIAG-DELEGATED",
      "user_message_id": "diag.host_delegation",
      "claim_policy": "never claim support when the symbol is absent from the current support matrix or marked as staged only",
      "meaning": "A diagnostic fixture for a path that would delegate to host glibc; current releases must make the claim-blocking state explicit."
    },
    {
      "id": "raw_syscall",
      "diagnostic_code": "FLC-DIAG-RAWSYSCALL",
      "user_message_id": "diag.raw_syscall",
      "claim_policy": "may claim support only for the declared syscall-backed scope and current fixtures",
      "meaning": "FrankenLibC selected direct Linux syscall marshaling."
    },
    {
      "id": "deterministic_fallback",
      "diagnostic_code": "FLC-DIAG-FALLBACK",
      "user_message_id": "diag.deterministic_fallback",
      "claim_policy": "block full semantic parity claims until the semantic overlay row is closed",
      "meaning": "The symbol has a deterministic fallback contract rather than full upstream behavior."
    },
    {
      "id": "hardened_repair",
      "diagnostic_code": "FLC-DIAG-REPAIR",
      "user_message_id": "diag.hardened_repair",
      "claim_policy": "may claim hardened repair only for a current repair/deny matrix row and fixture reference",
      "meaning": "Hardened mode selected a deterministic repair action."
    },
    {
      "id": "denial",
      "diagnostic_code": "FLC-DIAG-DENY",
      "user_message_id": "diag.denial",
      "claim_policy": "do not count denied unsupported inputs as successful support",
      "meaning": "Hardened mode denied an unsafe or unsupported input class."
    },
    {
      "id": "unsupported_symbol",
      "diagnostic_code": "FLC-DIAG-UNSUPPORTED",
      "user_message_id": "diag.unsupported_symbol",
      "claim_policy": "never claim behavior support from link-compatible unsupported platform contracts",
      "meaning": "The exported symbol exists for compatibility but the semantic overlay marks the behavior unsupported."
    },
    {
      "id": "noop_fallback",
      "diagnostic_code": "FLC-DIAG-NOOP",
      "user_message_id": "diag.noop_fallback",
      "claim_policy": "never treat no-op compatibility as full semantic parity",
      "meaning": "The symbol intentionally returns a no-op compatibility result."
    }
  ],
  "records": [
